# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here (optional, for broadcasting)

# Telegram Broadcasting (optional)
BROADCAST_NEWS_INTERVAL_MINUTES=30
BROADCAST_SELF_AD_INTERVAL_HOURS=4
BROADCAST_MIN_LIQUIDITY_USD=30000  # Minimum liquidity for signals (lower to 1000 for testing)
BROADCAST_MIN_NEWS_RELEVANCE=60    # Minimum relevance score for news (lower to 40 for testing)

# Admin Configuration
# Comma-separated list of Telegram user IDs with admin access
ADMIN_IDS=123456789,987654321

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WSS_URL=wss://api.mainnet-beta.solana.com

# Database
DB_PATH=trade_bot.db  # Legacy SQLite (fallback if DATABASE_URL not set)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require  # Neon PostgreSQL

# Server
PORT=10000
WEB_PORT=5000
RENDER_EXTERNAL_URL=your_render_url_here

# Security & Encryption
ENCRYPTION_MASTER_PASSWORD=change_this_to_secure_password_32_chars_min

# Logging
LOG_LEVEL=INFO

# Copy Trading
COPY_TRADE_CHECK_INTERVAL=10
WALLET_MONITOR_INTERVAL=5
SLIPPAGE_TOLERANCE=2.0
MIN_TRADE_AMOUNT=0.01

# Risk Management
DEFAULT_STOPLOSS_PERCENT=5.0
DEFAULT_TAKEPROFIT_PERCENT=10.0
MAX_POSITION_SIZE_PERCENT=10.0

# MEV Protection
JITO_TIP_AMOUNT=0.001
USE_PRIVATE_POOLS=true

# Hardware Wallet
PHANTOM_URL=https://phantom.app/
LEDGER_DERIVATION_PATH=m/44'/501'/0'/0'
